{
  "name": "miya-desktop",
  "version": "1.0.0",
  "description": "弥娅桌面端 - Vue 3 + Electron",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npx vite",
    "dev:electron": "npx electron . --disable-gpu --disable-software-rasterizer --disable-gpu-compositing",
    "dev:all": "concurrently \"npx vite\" \"wait-on http://localhost:5173 && npx electron .\"",
    "build:electron": "npx vite build --mode electron",
    "build": "vue-tsc && npx vite build && npx electron-builder",
    "build:dir": "vue-tsc && npx vite build && npx electron-builder --dir",
    "preview": "npx vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore"
  },
  "dependencies": {
    "@monaco-editor/loader": "^1.4.0",
    "@vueuse/core": "^10.9.0",
    "axios": "^1.6.7",
    "chart.js": "^4.4.2",
    "dompurify": "^3.0.8",
    "marked": "^12.0.1",
    "monaco-editor": "^0.45.0",
    "pinia": "^2.1.7",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10",
    "primeicons": "^7.0.0",
    "primevue": "^3.52.0",
    "vue": "^3.4.21",
    "vue-chartjs": "^5.3.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.28",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.4.0",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.6",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.miya.desktop",
    "productName": "弥娅",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "resources/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "resources/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "resources/icon.png",
      "category": "Utility"
    }
  }
}
