# ========================================
# 弥娅 MIYA - 完整配置文件
# ========================================
# 说明：
# 1. 复制此文件为 .env 并根据实际情况修改
# 2. 所有配置项都有注释说明
# 3. 部分配置项为可选，可根据需要启用
# ========================================

# ========================================
# 应用配置
# ========================================
# 调试模式：true/false
DEBUG=false

# 日志级别：DEBUG/INFO/WARNING/ERROR/CRITICAL
LOG_LEVEL=INFO

# 日志文件路径（可选）
LOG_FILE_PATH=logs/miya.log

# 日志文件最大大小（MB）
LOG_MAX_SIZE=100

# 日志文件备份数量
LOG_BACKUP_COUNT=10

# ========================================
# AI大模型配置
# ========================================
# AI提供商：openai, deepseek, anthropic, zhipu
AI_PROVIDER=openai

# OpenAI API密钥
AI_OPENAI_API_KEY=sk-your-openai-api-key

# OpenAI API基础URL（可选，用于代理或兼容接口）
AI_OPENAI_BASE_URL=

# OpenAI模型名称
AI_OPENAI_MODEL=gpt-4o

# DeepSeek API密钥
AI_DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# DeepSeek API基础URL（可选）
AI_DEEPSEEK_BASE_URL=

# DeepSeek模型名称
AI_DEEPSEEK_MODEL=deepseek-chat

# Anthropic API密钥
AI_ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Anthropic模型名称
AI_ANTHROPIC_MODEL=claude-3-sonnet-20240229

# 智谱AI API密钥
AI_ZHIPU_API_KEY=your-zhipu-api-key

# 智谱AI模型名称
AI_ZHIPU_MODEL=glm-4

# AI生成参数（可选）
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000

# ========================================
# QQ机器人配置
# ========================================
# OneBot WebSocket地址
QQ_ONEBOT_WS_URL=ws://localhost:3001

# OneBot访问令牌（可选）
QQ_ONEBOT_TOKEN=

# 机器人QQ号
QQ_BOT_QQ=0

# 超级管理员QQ号（可多个，逗号分隔）
QQ_SUPERADMIN_QQ=0

# 群聊白名单（可选，逗号分隔）
QQ_GROUP_WHITELIST=

# 群聊黑名单（可选，逗号分隔）
QQ_GROUP_BLACKLIST=

# 用户白名单（可选，逗号分隔）
QQ_USER_WHITELIST=

# 用户黑名单（可选，逗号分隔）
QQ_USER_BLACKLIST=

# ========================================
# Redis配置（可选，用于涨潮记忆）
# ========================================
# Redis主机地址
REDIS_HOST=localhost

# Redis端口
REDIS_PORT=6379

# Redis数据库索引
REDIS_DB=0

# Redis密码（可选）
# REDIS_PASSWORD=your_redis_password

# Redis连接池大小
REDIS_MAX_CONNECTIONS=10

# ========================================
# Milvus配置（可选，用于向量长期记忆）
# ========================================
# Milvus主机地址
MILVUS_HOST=localhost

# Milvus端口
MILVUS_PORT=19530

# 集合名称
MILVUS_COLLECTION=miya_memory

# 向量维度（根据embedding模型）
MILVUS_DIMENSION=1536

# 索引类型（IVF_FLAT/HNSW/IVF_PQ）
MILVUS_INDEX_TYPE=IVF_FLAT

# 索引参数（根据索引类型）
MILVUS_INDEX_PARAMS={"nlist":128}

# ========================================
# Neo4j配置（可选，用于知识图谱）
# ========================================
# Neo4j连接URI
NEO4J_URI=bolt://localhost:7687

# Neo4j用户名
NEO4J_USER=neo4j

# Neo4j密码
# NEO4J_PASSWORD=your_neo4j_password

# Neo4j数据库（可选）
NEO4J_DATABASE=neo4j

# ========================================
# 人格配置（0.0-1.0）
# ========================================
# 温暖度：影响回应的亲和力
PERSONALITY_WARMTH=0.8

# 逻辑性：影响推理的严谨度
PERSONALITY_LOGIC=0.7

# 创造力：影响回答的多样性
PERSONALITY_CREATIVITY=0.6

# 共情力：影响情感理解
PERSONALITY_EMPATHY=0.75

# 韧性：影响抗压能力
PERSONALITY_RESILIENCE=0.7

# ========================================
# 情绪配置
# ========================================
# 情绪衰减率（0.0-1.0）
EMOTION_DECAY_RATE=0.1

# 情绪染色阈值（0.0-1.0）
EMOTION_COLORING_THRESHOLD=0.7

# 情绪传播系数（0.0-1.0）
EMOTION_PROPAGATION_COEFF=0.3

# ========================================
# 信任配置
# ========================================
# 信任衰减率（0.0-1.0）
TRUST_DECAY_RATE=0.05

# 初始信任分数（0.0-1.0）
TRUST_INITIAL_SCORE=0.5

# 高信任阈值（0.0-1.0）
TRUST_HIGH_THRESHOLD=0.7

# 低信任阈值（0.0-1.0）
TRUST_LOW_THRESHOLD=0.3

# ========================================
# 记忆配置
# ========================================
# 潮汐记忆TTL（秒）
MEMORY_TIDE_TTL=3600

# 梦境压缩阈值（条数）
MEMORY_DREAM_THRESHOLD=100

# 短期记忆容量
MEMORY_SHORT_TERM_CAPACITY=20

# 长期记忆检索数量
MEMORY_LONG_TERM_RETRIEVAL=10

# ========================================
# 感知配置
# ========================================
# 感知激活率（0.0-1.0）
PERCEPTION_ACTIVATION_RATE=0.3

# 感知强度阈值（0.0-1.0）
PERCEPTION_INTENSITY_THRESHOLD=0.5

# ========================================
# 检测配置
# ========================================
# 时间环绕检测阈值（秒）
DETECTION_TIME_THRESHOLD=3600

# 空间环绕检测阈值（0.0-1.0）
DETECTION_SPACE_THRESHOLD=1.0

# 节点交叉检测阈值（0.0-1.0）
DETECTION_NODE_THRESHOLD=0.5

# ========================================
# 演化配置
# ========================================
# 沙盒启用
SANDBOX_ENABLED=true

# A/B测试启用
AB_TEST_ENABLED=true

# 用户共演启用
USER_CO_PLAY_ENABLED=true

# ========================================
# Runtime API配置
# ========================================
# API启用
API_ENABLED=true

# API监听地址
API_HOST=0.0.0.0

# API监听端口
API_PORT=8000

# API认证密钥（可选）
# API_AUTH_KEY=your_api_key

# OpenAPI文档启用
API_OPENAPI_ENABLED=true

# ========================================
# WebUI配置
# ========================================
# WebUI启用
WEBUI_ENABLED=true

# WebUI端口
WEBUI_PORT=8080

# WebUI密码（可选）
# WEBUI_PASSWORD=your_webui_password

# ========================================
# MCP配置
# ========================================
# MCP服务器启用
MCP_SERVER_ENABLED=false

# MCP服务器主机
MCP_SERVER_HOST=localhost

# MCP服务器端口
MCP_SERVER_PORT=9000

# ========================================
# IoT配置（可选）
# ========================================
# MQTT代理地址
MQTT_BROKER=localhost

# MQTT端口
MQTT_PORT=1883

# MQTT用户名（可选）
# MQTT_USERNAME=your_mqtt_username

# MQTT密码（可选）
# MQTT_PASSWORD=your_mqtt_password

# ========================================
# 队列配置
# ========================================
# AI请求间隔（秒）
AI_REQUEST_INTERVAL=1.0

# AI请求最大重试次数
AI_REQUEST_MAX_RETRIES=2

# 模型队列间隔（JSON格式）
QUEUE_INTERVALS={"chat_model":1.0,"vision_model":2.0,"agent_model":1.5}

# ========================================
# 语义动力学配置
# ========================================
# 语义衰减率
SEMANTIC_DECAY_RATE=0.05

# 语义组数量
SEMANTIC_GROUP_COUNT=10

# 元思考启用
META_THINKING_ENABLED=true

# 时域解析启用
TIME_EXPRESSION_PARSE_ENABLED=true

# ========================================
# AI客户端配置
# ========================================
# AI提供商（openai/deepseek/anthropic/zhipu）
AI_PROVIDER=openai

# OpenAI API配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# DeepSeek API配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 其他兼容OpenAI格式的API
CUSTOM_API_KEY=
CUSTOM_API_BASE=
CUSTOM_MODEL=

# 最大token数
AI_MAX_TOKENS=2000

# 温度（0.0-2.0，越高越随机）
AI_TEMPERATURE=0.7

# ========================================
# 提示词配置
# ========================================
# 系统提示词（弥娅的基础人格设定）
SYSTEM_PROMPT=你是弥娅（Miya），一个温暖、智慧、富有同理心的AI助手。你的五维人格特质为：温暖度0.8、逻辑性0.7、创造力0.6、同理心0.75、韧性0.7。你的回应应该体现出这些特质，始终保持友善、专业的态度。

# 用户提示词模板（可以包含占位符）
USER_PROMPT_TEMPLATE=用户输入：{user_input}

# 启用记忆上下文（将历史对话添加到提示词）
ENABLE_MEMORY_CONTEXT=true

# 记忆上下文最大条数
MEMORY_CONTEXT_MAX_COUNT=5

# 启用人格上下文（将人格向量添加到提示词）
ENABLE_PERSONALITY_CONTEXT=true

# ========================================
# 性能配置
# ========================================
# 最大并发任务数
MAX_CONCURRENT_TASKS=10

# 任务超时时间（秒）
TASK_TIMEOUT=60

# 内存使用限制（MB）
MEMORY_LIMIT=2048

# ========================================
# 安全配置
# ========================================
# 注入检测启用
INJECTION_DETECTION_ENABLED=true

# 敏感词过滤启用
SENSITIVE_WORD_FILTER_ENABLED=true

# 限流启用
RATE_LIMIT_ENABLED=true

# 限流次数（每分钟）
RATE_LIMIT_PER_MINUTE=30

# ========================================
# 日志配置
# ========================================
# 终端日志启用
LOG_TTY_ENABLED=true

# 日志格式（text/json）
LOG_FORMAT=text

# 日志日期格式
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S

# ========================================
# LifeBook 记忆管理配置
# ========================================
# LifeBook 启用
LIFEBOOK_ENABLED=true

# LifeBook 数据目录
LIFEBOOK_BASE_DIR=data/lifebook

# 自动总结启用（需要 AI 客户端）
LIFEBOOK_AUTO_SUMMARY=false

# 默认回溯月数
LIFEBOOK_DEFAULT_MONTHS_BACK=1
